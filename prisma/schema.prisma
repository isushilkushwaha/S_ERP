generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  TEACHER
}

enum AdminType {
  PRIMARY
  SECONDARY
}

model Role {
  id              String           @id @default(cuid())
  name            RoleName         @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]
}

model User {
  id           String     @id @default(uuid())
  fullName     String
  email        String     @unique
  username     String     @unique
  passwordHash String
  roleId       String
  adminType    AdminType?
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  accounts     Account[]
  sessions     Session[]
  role         Role       @relation(fields: [roleId], references: [id])

  @@index([email])
  @@index([username])
  @@index([roleId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Permission {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ==============================
// ENUMS
// ==============================

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentCategory {
  GENERAL
  OBC
  SC
  ST
  EWS
  MINORITY
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  ALUMNI
  TRANSFERRED
}

enum AcademicYearStatus {
  ACTIVE
  CLOSED
}

enum Medium {
  ENGLISH
  HINDI
  BOTH
}

enum AdmissionType {
  NEW
  PROMOTION
  TRANSFER
  READMISSION
}

enum EnrollmentStatus {
  ACTIVE
  PROMOTED
  PASSED_OUT
  TRANSFERRED
  LEFT
}

enum Stream {
  SCIENCE
  COMMERCE
  ARTS
}

enum DocumentType {
  AADHAAR
  PHOTO
  BIRTH_CERTIFICATE
  TRANSFER_CERTIFICATE
  CASTE_CERTIFICATE
  INCOME_CERTIFICATE
  MARKSHEET
  OTHER
}

model AcademicYear {
  id          String             @id @default(uuid())
  name        String             @unique
  code        String?            @unique
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean            @default(false)
  status      AcademicYearStatus @default(ACTIVE)
  description String?

  enrollments StudentEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Class {
  id           String  @id @default(uuid())
  name         String
  numericOrder Int
  medium       Medium  @default(ENGLISH)
  description  String?

  sections    Section[]
  enrollments StudentEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
  @@index([numericOrder])
}

model Section {
  id String @id @default(uuid())

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  name String

  classTeacherId String?
  roomNumber     String?
  capacity       Int?

  isActive Boolean @default(true)

  enrollments StudentEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, name])
}

model Student {
  id String @id @default(uuid())

  studentCode     String @unique
  admissionNumber String @unique

  emisNumber String?
  apaarId    String?
  penNumber  String?

  firstName  String
  middleName String?
  lastName   String

  gender      Gender
  dateOfBirth DateTime

  bloodGroup  String?
  religion    String?
  category    StudentCategory?
  caste       String?
  nationality String?

  aadhaarNumber      String? @unique
  birthCertificateNo String?

  email  String?
  mobile String?

  photo String?

  admissionDate  DateTime
  previousSchool String?

  status StudentStatus @default(ACTIVE)

  remarks String?

  fatherName       String
  fatherOccupation String?
  fatherMobile     String
  fatherEmail      String?

  motherName       String?
  motherOccupation String?
  motherMobile     String?
  motherEmail      String?

  guardianName     String?
  guardianRelation String?
  guardianMobile   String?
  guardianEmail    String?

  addressLine1 String
  addressLine2 String?

  city       String
  district   String
  state      String
  country    String @default("India")
  postalCode String

  isTransportRequired Boolean @default(false)
  isHostelRequired    Boolean @default(false)

  enrollments StudentEnrollment[]
  documents   StudentDocument[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([studentCode])
  @@index([admissionNumber])
  @@index([aadhaarNumber])
}

model StudentEnrollment {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])

  rollNumber Int

  medium Medium
  stream Stream?

  house                   String?
  boardRegistrationNumber String?

  admissionType AdmissionType

  enrollmentStatus EnrollmentStatus @default(ACTIVE)

  joinedDate DateTime
  leftDate   DateTime?

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, academicYearId])
  @@unique([academicYearId, classId, sectionId, rollNumber])
  @@index([academicYearId, classId, sectionId])
}

model StudentDocument {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  documentType DocumentType

  documentNumber String?

  fileName String
  fileUrl  String

  mimeType String?
  fileSize Int?

  issueDate  DateTime?
  expiryDate DateTime?

  verified Boolean @default(false)

  remarks String?

  createdAt DateTime @default(now())
}
